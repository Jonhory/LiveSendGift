{
  "version": 1,
  "indentation": {
    "spaces": 4
  },
  "lineLength": 120,
  "maximumBlankLines": 1,
  "respectsExistingLineBreaks": true,
  "lineBreakBeforeEachArgument": false,
  "indentConditionalCompilationBlocks": false,
  "rules": {
    "AlwaysUseLowerCamelCase": false,
    "NoBlockComments": false
  }
}
